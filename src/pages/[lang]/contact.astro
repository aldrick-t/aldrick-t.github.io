---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactPageContent from '../../components/ContactPageContent.astro';
import { siteConfig } from '../../config/site';
import { localizedLanguages, ui, type LocalizedLanguage } from '../../lib/i18n';

export function getStaticPaths() {
  return localizedLanguages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as LocalizedLanguage;
const labels = ui[lang];
---

<BaseLayout title={`${labels.contactPage.title} — ${siteConfig.name}`} description={labels.contactPage.description} lang={lang} path="/contact">
  <ContactPageContent lang={lang} />
</BaseLayout>
