---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotFoundContent from '../../components/NotFoundContent.astro';
import { siteConfig } from '../../config/site';
import { localizedLanguages, ui, type LocalizedLanguage } from '../../lib/i18n';

export function getStaticPaths() {
  return localizedLanguages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as LocalizedLanguage;
const labels = ui[lang];
---

<BaseLayout title={`404 — ${siteConfig.name}`} description={labels.notFound.description} lang={lang} path="/404">
  <NotFoundContent lang={lang} />
</BaseLayout>
