---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CvPageContent from '../../components/CvPageContent.astro';
import { siteConfig } from '../../config/site';
import { localizedLanguages, ui, type LocalizedLanguage } from '../../lib/i18n';

export function getStaticPaths() {
  return localizedLanguages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as LocalizedLanguage;
const labels = ui[lang];
---

<BaseLayout title={`${labels.cvPage.title} — ${siteConfig.name}`} description={labels.cvPage.description} lang={lang} path="/cv">
  <CvPageContent lang={lang} />
</BaseLayout>
