---
import BaseLayout from '../layouts/BaseLayout.astro';
import CvPreviewPanel from '../components/CvPreviewPanel.astro';
import { cvVariants, defaultCvVariant } from '../data/cv';
---

<BaseLayout title="CV | Aldrick Tadeo" description="Preview and download Aldrick Tadeo's engineering CV.">
  <div class="shell flow-layout">
    <section>
      <p class="eyebrow">Curriculum Vitae</p>
      <h1>CV Preview</h1>
      <p>
        Each CV variant is authored in Typst and exported to PDF through GitHub Actions. The
        embedded preview below always reflects the currently selected variant.
      </p>
    </section>

    <CvPreviewPanel variants={cvVariants} defaultVariant={defaultCvVariant} />
  </div>
</BaseLayout>
