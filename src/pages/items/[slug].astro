---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ItemPageContent from '../../components/ItemPageContent.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localizeItems } from '../../lib/localized-items';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const items = (await getCollection('items')).filter((item) => item.data.published);
  return items.map((item) => ({ params: { slug: item.id }, props: { item, allItems: items } }));
}

interface Props { item: CollectionEntry<'items'>; allItems: CollectionEntry<'items'>[] }
const { item, allItems } = Astro.props;
const { Content } = await render(item);
const lang = 'en';
const localizedItems = localizeItems(allItems, new Map(), lang);
const localizedItem = localizedItems.find((entry) => entry.id === item.id) ?? item;
---

<BaseLayout title={`${localizedItem.data.title} — ${siteConfig.name}`} description={localizedItem.data.summary} lang={lang} path={`/items/${item.id}`}>
  <ItemPageContent item={localizedItem} allItems={localizedItems} Content={Content} lang={lang} />
</BaseLayout>
