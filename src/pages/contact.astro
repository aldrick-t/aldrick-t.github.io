---
import Icon from '../components/Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';

const contactMethods = [
  {
    label: 'Email',
    value: siteConfig.contact.primaryEmail,
    href: `mailto:${siteConfig.contact.primaryEmail}`,
    icon: 'email' as const,
    external: false
  },
  {
    label: 'Academic Email',
    value: siteConfig.contact.academicEmail,
    href: `mailto:${siteConfig.contact.academicEmail}`,
    icon: 'email' as const,
    external: false
  },
  {
    label: 'Phone',
    value: siteConfig.contact.phone,
    href: `tel:${siteConfig.contact.phone.replace(/[^\d+]/g, '')}`,
    icon: 'phone' as const,
    external: false
  },
  {
    label: 'GitHub',
    value: siteConfig.githubUrl,
    href: siteConfig.githubUrl,
    icon: 'github' as const,
    external: true
  },
  {
    label: 'LinkedIn',
    value: siteConfig.linkedinUrl,
    href: siteConfig.linkedinUrl,
    icon: 'linkedin' as const,
    external: true
  }
];
---

<BaseLayout title="Contact | Aldrick Tadeo" description="Direct contact links and quick-copy details.">
  <div class="shell flow-layout">
    <section>
      <p class="eyebrow">Contact</p>
      <h1>Reach Out</h1>
      <p>
        I'm always open to discussing new projects, work opportunities, or just connecting with like-minded professionals. Feel free to reach out through any of the methods below!
      </p>
    </section>

    <section class="contact-list" aria-label="Contact methods">
      {
        contactMethods.map((item) => (
          <article class="contact-card glass-panel">
            <div class="contact-card__identity">
              <span class="contact-card__icon" aria-hidden="true">
                <Icon name={item.icon} />
              </span>
              <div>
                <p class="eyebrow">{item.label}</p>
                <h2>{item.value}</h2>
              </div>
            </div>
            <div class="contact-card__actions">
              <a
                class="btn"
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noreferrer noopener' : undefined}
              >
                Open {item.label}
              </a>
              <button
                class="copy-button"
                type="button"
                data-copy-value={item.value}
                aria-label={`Copy ${item.label}`}
              >
                <Icon name="copy" />
                <span class="copy-button__label">Copy</span>
              </button>
            </div>
          </article>
        ))
      }
    </section>
  </div>

  <script>
    const copyButtons = document.querySelectorAll<HTMLButtonElement>('[data-copy-value]');

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const value = button.dataset.copyValue;
        if (!value) {
          return;
        }

        try {
          await navigator.clipboard.writeText(value);
          const label = button.querySelector<HTMLElement>('.copy-button__label');
          const originalText = label?.textContent ?? 'Copy';
          if (label) {
            label.textContent = 'Copied';
          }
          button.classList.add('is-copied');
          window.setTimeout(() => {
            if (label) {
              label.textContent = originalText;
            }
            button.classList.remove('is-copied');
          }, 1600);
        } catch {
          button.classList.add('is-copy-error');
          window.setTimeout(() => {
            button.classList.remove('is-copy-error');
          }, 1600);
        }
      });
    });
  </script>
</BaseLayout>
