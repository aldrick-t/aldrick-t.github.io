---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDateRange, groupItemsByType } from '../../lib/items';

const items = (await getCollection('items')).filter((item) => item.data.published && item.data.portfolio);
const groups = groupItemsByType(items);
---

<BaseLayout title="Portfolio — Aldrick Tadeo" description="All of Aldrick Tadeo's projects, experience, education, recognition, service, and continued learning.">
  <div class="shell page-stack">
    <header class="page-header">
      <p class="mono-label">Complete index</p>
      <h1>Portfolio</h1>
      <p>Projects, experience, education, recognition, service, and continued learning.</p>
    </header>
    <nav class="section-nav" aria-label="Portfolio sections">
      {groups.map((group) => <a href={`#${group.type}`}>{group.label} <span>{group.items.length}</span></a>)}
    </nav>
    {groups.map((group) => (
      <section id={group.type} class="page-section portfolio-group" aria-labelledby={`${group.type}-title`}>
        <header class="section-heading"><h2 id={`${group.type}-title`}>{group.label}</h2><span>{group.items.length}</span></header>
        <div class="row-list">
          {group.items.map((item) => (
            <article class="portfolio-row">
              <div class="portfolio-row__date"><time>{formatDateRange(item)}</time></div>
              <div><h3><a href={`/items/${item.slug}`}>{item.data.title}</a></h3>{item.data.organization ? <p>{item.data.organization}</p> : null}<p>{item.data.summary}</p></div>
              <a class="portfolio-row__arrow" href={`/items/${item.slug}`} aria-label={`Open ${item.data.title}`}>→</a>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
