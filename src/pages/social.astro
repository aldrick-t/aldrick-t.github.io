---
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkedInBadgePanel from '../components/LinkedInBadgePanel.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout
  title="Social | Aldrick Tadeo"
  description="LinkedIn-focused social page with profile embed and direct connection links."
>
  <div class="shell flow-layout">
    <section>
      <p class="eyebrow">Professional Social Presence</p>
      <h1>LinkedIn Focus</h1>
      <p>
        This page centralizes LinkedIn access and profile context with graceful fallbacks for browsers
        that block embeds.
      </p>
    </section>

    <LinkedInBadgePanel profileUrl={siteConfig.linkedinUrl} badgeConfig={siteConfig.socialBadgeConfig} />
  </div>
</BaseLayout>
