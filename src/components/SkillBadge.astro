---
import { skillIconRegistry, type SkillIconName } from '../data/iconRegistry';

interface Props {
  label: string;
  icon?: SkillIconName;
  size?: 'default' | 'large';
}

const { label, icon, size = 'default' } = Astro.props;
const svg = icon ? skillIconRegistry[icon] : undefined;

const fallback = label
  .split(/[^A-Za-z0-9#+]+/)
  .filter(Boolean)
  .map((part) => part[0])
  .join('')
  .slice(0, 3)
  .toUpperCase();
---

<span class:list={{ 'skill-badge': true, 'skill-badge--large': size === 'large' }} aria-hidden="true">
  {
    svg ? (
      <span class="skill-badge__icon" set:html={svg} />
    ) : (
      <span class="skill-badge__text">{fallback}</span>
    )
  }
</span>
