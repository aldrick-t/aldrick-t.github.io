---
import type { CvVariant } from '../data/cv';
import { ui, type Language } from '../lib/i18n';

interface Props { variants: CvVariant[]; defaultVariant: CvVariant; lang?: Language }
const { variants, defaultVariant, lang = 'en' } = Astro.props;
const labels = ui[lang];
const localizedVariants = variants.map((variant) => ({
  ...variant,
  label: labels.cvPage.variants[variant.id]
}));
const localizedDefaultVariant = localizedVariants.find((variant) => variant.id === defaultVariant.id) ?? localizedVariants[0];
---

<section class="cv-viewer" aria-label={labels.cvPage.previewAria}>
  <div class="cv-viewer__toolbar" data-cv-panel data-default-variant={defaultVariant.id} data-variants={JSON.stringify(localizedVariants)} data-previewing-label={labels.cvPage.previewing}>
    <div class="cv-viewer__variants" role="tablist" aria-label={labels.cvPage.variantsAria}>
      {localizedVariants.map((variant) => (
        <button type="button" role="tab" data-cv-variant={variant.id} aria-selected={variant.id === defaultVariant.id ? 'true' : 'false'}>{variant.label}</button>
      ))}
    </div>
    <a class="button button--primary" href={defaultVariant.publicPath} download data-cv-download>{labels.common.downloadPdf}</a>
  </div>
  <p class="cv-viewer__status" aria-live="polite" data-cv-status>{labels.cvPage.previewing} {localizedDefaultVariant.label}</p>
  <object data={defaultVariant.publicPath} type="application/pdf" class="cv-viewer__embed" data-cv-embed>
    <div class="cv-viewer__fallback">
      <p>{labels.cvPage.fallback}</p>
      <a href={defaultVariant.publicPath} download data-cv-fallback>{labels.cvPage.fallbackDownload}</a>
    </div>
  </object>
</section>

<script>
  type BrowserCvVariant = { id: string; label: string; publicPath: string };
  document.querySelectorAll<HTMLElement>('[data-cv-panel]').forEach((panel) => {
    const variants = JSON.parse(panel.dataset.variants ?? '[]') as BrowserCvVariant[];
    const defaultId = panel.dataset.defaultVariant;
    const previewingLabel = panel.dataset.previewingLabel ?? 'Previewing';
    const root = panel.closest('.cv-viewer');
    const buttons = Array.from(panel.querySelectorAll<HTMLButtonElement>('[data-cv-variant]'));
    const download = panel.querySelector<HTMLAnchorElement>('[data-cv-download]');
    const status = root?.querySelector<HTMLElement>('[data-cv-status]');
    const embed = root?.querySelector<HTMLObjectElement>('[data-cv-embed]');
    const fallback = root?.querySelector<HTMLAnchorElement>('[data-cv-fallback]');
    if (!(variants.length && download && status && embed && fallback)) return;

    const select = (id: string | null) => {
      const variant = variants.find((entry) => entry.id === id) ?? variants.find((entry) => entry.id === defaultId) ?? variants[0];
      status.textContent = `${previewingLabel} ${variant.label}`;
      download.href = variant.publicPath;
      embed.data = variant.publicPath;
      fallback.href = variant.publicPath;
      buttons.forEach((button) => button.setAttribute('aria-selected', String(button.dataset.cvVariant === variant.id)));
      const url = new URL(window.location.href);
      variant.id === defaultId ? url.searchParams.delete('variant') : url.searchParams.set('variant', variant.id);
      window.history.replaceState({}, '', `${url.pathname}${url.search}`);
    };
    buttons.forEach((button) => button.addEventListener('click', () => select(button.dataset.cvVariant ?? null)));
    select(new URL(window.location.href).searchParams.get('variant'));
  });
</script>
