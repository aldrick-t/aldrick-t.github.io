---
import { siteConfig } from '../config/site';
import { ui, type Language } from '../lib/i18n';

interface Props {
  lang?: Language;
}

const { lang = 'en' } = Astro.props;
const labels = ui[lang];
const contacts = [
  { label: labels.footer.email, value: siteConfig.email, href: `mailto:${siteConfig.email}`, external: false },
  { label: 'GitHub', value: 'github.com/aldrick-t', href: siteConfig.githubUrl, external: true },
  { label: 'LinkedIn', value: 'linkedin.com/in/aldrick-t', href: siteConfig.linkedinUrl, external: true }
];
---

<div class="shell page-stack contact-page">
  <header class="page-header"><p class="mono-label">{labels.contactPage.eyebrow}</p><h1>{labels.contactPage.title}</h1><p>{labels.contactPage.intro}</p></header>
  <div class="contact-list">
    {contacts.map((contact) => (
      <article class="contact-row">
        <div><span class="mono-label">{contact.label}</span><h2><a href={contact.href} target={contact.external ? '_blank' : undefined} rel={contact.external ? 'noreferrer noopener' : undefined}>{contact.value}{contact.external ? ` ${labels.common.externalSuffix}` : ''}</a></h2></div>
        <button
          type="button"
          class="copy-control"
          data-copy={contact.value}
          data-copy-label={labels.common.copy}
          data-copied-label={labels.common.copied}
          data-copy-failed-label={labels.common.selectAndCopy}
        >
          {labels.common.copy}
        </button>
      </article>
    ))}
  </div>
</div>
<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((button) => button.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(button.dataset.copy ?? '');
      button.textContent = button.dataset.copiedLabel ?? 'Copied';
      window.setTimeout(() => { button.textContent = button.dataset.copyLabel ?? 'Copy'; }, 1400);
    } catch { button.textContent = button.dataset.copyFailedLabel ?? 'Select and copy'; }
  }));
</script>
