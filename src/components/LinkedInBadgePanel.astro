---
interface BadgeConfig {
  locale: string;
  vanity: string;
  size: 'small' | 'medium' | 'large';
}

interface Props {
  profileUrl: string;
  badgeConfig: BadgeConfig;
}

const { profileUrl, badgeConfig } = Astro.props;
---

<section class="linkedin-panel" aria-label="LinkedIn profile section">
  <div class="linkedin-panel__intro">
    <h2>LinkedIn Focus</h2>
    <p>
      Follow current updates, career timeline, and professional highlights. If the embed is
      blocked on your browser, use the direct profile actions below.
    </p>
  </div>

  <div class="linkedin-panel__embed">
    <script is:inline src="https://platform.linkedin.com/badges/js/profile.js" async defer></script>
    <div
      class="badge-base LI-profile-badge"
      data-locale={badgeConfig.locale}
      data-size={badgeConfig.size}
      data-theme="light"
      data-type="VERTICAL"
      data-vanity={badgeConfig.vanity}
      data-version="v1"
    >
      <a class="badge-base__link LI-simple-link" href={profileUrl}>LinkedIn Profile</a>
    </div>
  </div>

  <div class="linkedin-panel__actions">
    <a class="btn btn--primary" href={profileUrl} target="_blank" rel="noreferrer noopener">
      Open LinkedIn Profile
    </a>
    <a class="btn" href={`${profileUrl}detail/contact-info/`} target="_blank" rel="noreferrer noopener">
      Connect on LinkedIn
    </a>
  </div>

  <div class="linkedin-panel__fallback">
    <h3>Highlights</h3>
    <ul>
      <li>Engineering project breakdowns and production outcomes.</li>
      <li>Career progress, roles, and technical leadership activities.</li>
      <li>Collaboration and communication style in real teams.</li>
    </ul>
  </div>
</section>
