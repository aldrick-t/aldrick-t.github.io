---
import { itemPath, ui, type Language } from '../lib/i18n';
import { getPublishedLocalizedItems } from '../lib/localized-items';
import { formatDateRange, groupItemsByType } from '../lib/items';

interface Props {
  lang?: Language;
}

const { lang = 'en' } = Astro.props;
const labels = ui[lang];
const items = await getPublishedLocalizedItems(lang, (item) => item.data.portfolio);
const groups = groupItemsByType(items, lang);
---

<div class="shell page-stack page-stack--sticky-section-nav">
  <header class="page-header">
    <h1>{labels.portfolioPage.title}</h1>
    <p>{labels.portfolioPage.intro}</p>
  </header>
  <nav class="section-nav section-nav--sticky" aria-label={labels.portfolioPage.sectionsAria}>
    {groups.map((group) => <a href={`#${group.type}`}>{group.label} <span>{group.items.length}</span></a>)}
  </nav>
  {groups.map((group) => (
    <section id={group.type} class="page-section portfolio-group" aria-labelledby={`${group.type}-title`}>
      <header class="section-heading"><h2 id={`${group.type}-title`}>{group.label}</h2><span>{group.items.length}</span></header>
      <div class="row-list">
        {group.items.map((item) => (
          <article class="portfolio-row">
            <div class="portfolio-row__date"><time>{formatDateRange(item, lang)}</time></div>
            <div><h3><a href={itemPath(item.id, lang)}>{item.data.title}</a></h3>{item.data.organization ? <p>{item.data.organization}</p> : null}<p>{item.data.summary}</p></div>
            <a class="portfolio-row__arrow" href={itemPath(item.id, lang)} aria-label={`${labels.common.open} ${item.data.title}`}>→</a>
          </article>
        ))}
      </div>
    </section>
  ))}
</div>
