---
import { siteConfig } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell site-footer__inner">
    <p>{year} {siteConfig.name}</p>
    <div class="site-footer__links">
      <a href="/contact">Contact</a>
      <a href={siteConfig.githubUrl} target="_blank" rel="noreferrer noopener">GitHub</a>
      <a href={siteConfig.linkedinUrl} target="_blank" rel="noreferrer noopener">LinkedIn</a>
      <a href={`mailto:${siteConfig.contact.primaryEmail}`}>Email</a>
    </div>
  </div>
</footer>
