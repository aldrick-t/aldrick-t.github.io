---
interface Action {
  label: string;
  description: string;
  href: string;
  external?: boolean;
}

interface Props {
  actions: Action[];
}

const { actions } = Astro.props;
---

<section class="quick-access" aria-label="Quick access links">
  <h2>Quick Access</h2>
  <div class="quick-access__grid">
    {
      actions.map((action) => (
        <a
          class="quick-card"
          href={action.href}
          target={action.external ? '_blank' : undefined}
          rel={action.external ? 'noreferrer noopener' : undefined}
        >
          <h3>{action.label}</h3>
          <p>{action.description}</p>
        </a>
      ))
    }
  </div>
</section>
