---
import type { ItemEntry } from '../lib/items';
import { formatDateRange, itemTypeLabels } from '../lib/items';

interface Props { item: ItemEntry; featured?: boolean }
const { item, featured = false } = Astro.props;
---

<article class:list={{ 'item-card': true, 'item-card--featured': featured }}>
  <div class="item-card__meta">
    <span>{itemTypeLabels[item.data.type].replace(/s$/, '')}</span>
    <time>{formatDateRange(item)}</time>
  </div>
  <h3><a href={`/items/${item.slug}`}>{item.data.title}</a></h3>
  {item.data.organization ? <p class="item-card__organization">{item.data.organization}</p> : null}
  <p>{item.data.summary}</p>
  <a class="text-link" href={`/items/${item.slug}`}>Read item <span aria-hidden="true">→</span></a>
</article>
