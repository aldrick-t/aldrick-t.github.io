---
import type { ItemEntry } from '../lib/items';
import { formatDateRange } from '../lib/items';
import { getItemTypeLabel, itemPath, ui, type Language } from '../lib/i18n';

interface Props { item: ItemEntry; lang?: Language; featured?: boolean }
const { item, lang = 'en', featured = false } = Astro.props;
const labels = ui[lang];
---

<article class:list={{ 'item-card': true, 'item-card--featured': featured }}>
  <div class="item-card__meta">
    <span>{getItemTypeLabel(item.data.type, lang, 'singular')}</span>
    <time>{formatDateRange(item, lang)}</time>
  </div>
  <h3><a href={itemPath(item.id, lang)}>{item.data.title}</a></h3>
  {item.data.organization ? <p class="item-card__organization">{item.data.organization}</p> : null}
  <p>{item.data.summary}</p>
  <a class="text-link" href={itemPath(item.id, lang)}>{labels.common.readItem} <span aria-hidden="true">→</span></a>
</article>
