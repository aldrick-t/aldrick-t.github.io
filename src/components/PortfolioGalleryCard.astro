---
import type { ItemEntry } from '../lib/items';
import { formatDateRange } from '../lib/items';
import { getItemTypeLabel, itemPath, ui, type Language } from '../lib/i18n';

interface Props {
  item: ItemEntry;
  latestOrder: number;
  relevanceOrder: number;
  lang?: Language;
}

const { item, latestOrder, relevanceOrder, lang = 'en' } = Astro.props;
const labels = ui[lang];
const thumbnail = item.data.thumbnail;
const itemUrl = itemPath(item.id, lang);
const links = item.data.links.slice(0, 2);
---

<article
  class="portfolio-gallery-card"
  data-portfolio-item
  data-type={item.data.type}
  data-latest-order={latestOrder}
  data-relevance-order={relevanceOrder}
>
  <a class:list={{ 'portfolio-gallery-card__media': true, 'portfolio-gallery-card__media--empty': !thumbnail }} href={itemUrl} aria-label={`${labels.portfolioPage.openItem}: ${item.data.title}`}>
    {thumbnail ? (
      <img
        src={thumbnail.path}
        alt={thumbnail.alt}
        loading="lazy"
        decoding="async"
        style={thumbnail.objectPosition ? `object-position:${thumbnail.objectPosition}` : undefined}
      />
    ) : (
      <>
        <span>{getItemTypeLabel(item.data.type, lang, 'singular')}</span>
        <strong>{labels.portfolioPage.noThumbnail}</strong>
      </>
    )}
  </a>
  <div class="portfolio-gallery-card__body">
    <div class="portfolio-gallery-card__meta">
      <span>{getItemTypeLabel(item.data.type, lang, 'singular')}</span>
      <time>{formatDateRange(item, lang)}</time>
    </div>
    <h3><a href={itemUrl}>{item.data.title}</a></h3>
    {item.data.organization ? <p class="portfolio-gallery-card__organization">{item.data.organization}</p> : null}
    <p>{item.data.summary}</p>
    {item.data.tags.length ? <ul class="portfolio-gallery-card__tags">{item.data.tags.slice(0, 3).map((tag) => <li>{tag}</li>)}</ul> : null}
    <div class="portfolio-gallery-card__actions">
      <a class="text-link" href={itemUrl}>{labels.common.readItem} <span aria-hidden="true">→</span></a>
      {links.map((link) => (
        <a href={link.url} target="_blank" rel="noreferrer noopener">{link.label} {labels.common.externalSuffix}</a>
      ))}
    </div>
  </div>
</article>
