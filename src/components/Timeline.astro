---
import type { ItemEntry } from '../lib/items';
import { buildTimeline, formatDateRange } from '../lib/items';
import { getItemTypeLabel, itemPath, ui, type Language } from '../lib/i18n';

interface Props { items: ItemEntry[]; lang?: Language }
const { items, lang = 'en' } = Astro.props;
const labels = ui[lang];
const timeline = buildTimeline(items);
---

<div class="timeline" style={`--timeline-months:${timeline.totalMonths};--timeline-lanes:${timeline.laneCount}`}>
  <div class="timeline__years" aria-hidden="true">
    {timeline.years.map(({ year, offset }) => (
      <span style={`--year-offset:${offset}`}>{year}</span>
    ))}
  </div>
  <ol class="timeline__items">
    {timeline.placements.map(({ item, lane, rowStart, rowSpan, concurrent }) => (
      <li
        class:list={{ 'timeline-item': true, 'timeline-item--compact': rowSpan < 5 }}
        style={`--lane:${lane + 1};--row-start:${rowStart};--row-span:${rowSpan}`}
      >
        <a href={itemPath(item.id, lang)}>
          <span class="timeline-item__type">{getItemTypeLabel(item.data.type, lang, 'singular')}</span>
          <strong>{item.data.title}</strong>
          {rowSpan >= 5 ? <time>{formatDateRange(item, lang)}</time> : null}
          {rowSpan >= 5 && item.data.organization ? <span>{item.data.organization}</span> : null}
        </a>
        {concurrent.length ? (
          <span class="timeline-item__concurrent">
            {labels.timeline.concurrentWith} {concurrent.slice(0, 3).map((entry, index) => (
              <><a href={itemPath(entry.id, lang)}>{entry.data.title}</a>{index < Math.min(concurrent.length, 3) - 1 ? ', ' : ''}</>
            ))}
            {concurrent.length > 3 ? ` ${concurrent.length - 3} ${labels.timeline.more}` : ''}
          </span>
        ) : null}
      </li>
    ))}
  </ol>
</div>
