---
interface SectionLink {
  id: string;
  label: string;
  shortLabel: string;
}

interface Props {
  sections: SectionLink[];
}

const { sections } = Astro.props;
---

<aside class="section-index" aria-label="Page section index" data-section-index>
  <nav aria-label="Section navigation">
    <ul class="section-index__list section-index__list--desktop">
      {
        sections.map((section, index) => (
          <li>
            <a
              class:list={{ 'section-index__link': true, 'is-active': index === 0 }}
              href={`#${section.id}`}
              data-section-link={section.id}
              aria-current={index === 0 ? 'true' : undefined}
            >
              <span class="section-index__label">{section.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
    <div class="section-index__mobile">
      <ul class="section-index__list section-index__list--mobile">
        {
          sections.map((section, index) => (
            <li>
              <a
                class:list={{ 'section-index__dot-link': true, 'is-active': index === 0 }}
                href={`#${section.id}`}
                data-section-dot={section.id}
                aria-label={section.label}
                aria-current={index === 0 ? 'true' : undefined}
              >
                <span class="section-index__dot" aria-hidden="true" />
              </a>
            </li>
          ))
        }
      </ul>
      <span class="section-index__active-pill" data-section-active-label>{sections[0]?.label}</span>
    </div>
  </nav>
</aside>

<script>
  const widgets = document.querySelectorAll('[data-section-index]');

  widgets.forEach((widget) => {
    const links = Array.from(widget.querySelectorAll<HTMLAnchorElement>('[data-section-link]'));
    const dots = Array.from(widget.querySelectorAll<HTMLAnchorElement>('[data-section-dot]'));
    const activeLabel = widget.querySelector<HTMLElement>('[data-section-active-label]');
    const trackedSections = links
      .map((link) => {
        const id = link.dataset.sectionLink;
        const section = id ? document.getElementById(id) : null;
        return id && section ? { id, label: link.textContent?.trim() ?? id, section } : null;
      })
      .filter((entry): entry is { id: string; label: string; section: HTMLElement } => Boolean(entry));

    const setActive = (id: string) => {
      links.forEach((link) => {
        const isActive = link.dataset.sectionLink === id;
        link.classList.toggle('is-active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'true');
        } else {
          link.removeAttribute('aria-current');
        }
      });

      dots.forEach((dot) => {
        const isActive = dot.dataset.sectionDot === id;
        dot.classList.toggle('is-active', isActive);
        if (isActive) {
          dot.setAttribute('aria-current', 'true');
        } else {
          dot.removeAttribute('aria-current');
        }
      });

      if (activeLabel) {
        activeLabel.textContent = trackedSections.find((entry) => entry.id === id)?.label ?? id;
      }
    };

    if (!trackedSections.length) {
      return;
    }

    let ticking = false;

    const updateActive = () => {
      ticking = false;
      const anchor = window.innerHeight * 0.3;
      let activeId = trackedSections[0].id;

      trackedSections.forEach((entry) => {
        if (entry.section.getBoundingClientRect().top <= anchor) {
          activeId = entry.id;
        }
      });

      setActive(activeId);
    };

    const requestUpdate = () => {
      if (ticking) {
        return;
      }

      ticking = true;
      window.requestAnimationFrame(updateActive);
    };

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate, { passive: true });
    window.addEventListener('load', requestUpdate);
    requestUpdate();
  });
</script>
