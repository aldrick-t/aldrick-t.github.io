---
import { siteConfig } from '../config/site';
// import ThemeControl from './ThemeControl.astro';

const pathname = Astro.url.pathname;
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'CV', href: '/cv' },
  { label: 'Contact', href: '/contact' }
];

const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href) || (href === '/portfolio' && pathname.startsWith('/items/'));
---

<header class="site-header">
  <div class="site-header__inner shell shell--wide">
    <div class="site-header__identity">
      <a class="brand" href="/">{siteConfig.name}</a>
      <!-- <ThemeControl /> -->
    </div>
    <nav aria-label="Primary navigation">
      <ul class="primary-nav">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
